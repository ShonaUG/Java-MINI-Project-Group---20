<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.Bloom?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<StackPane prefHeight="700" prefWidth="900" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.java_lms_group_20.Controller.LoginController">

    <AnchorPane mouseTransparent="true">
        <Circle centerX="100" centerY="100" fill="#6366f111" radius="150" />
        <Circle centerX="800" centerY="600" fill="#a855f711" radius="200" />
    </AnchorPane>

    <VBox alignment="CENTER" maxHeight="580" maxWidth="440" spacing="0" style="-fx-background-color: white; -fx-background-radius: 24;                  -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 20, 0.5, 0, 10);                  -fx-border-color: #e2e8f0; -fx-border-radius: 24; -fx-border-width: 1;">

        <padding>
            <Insets bottom="60" left="50" right="50" top="60" />
        </padding>
      <VBox alignment="CENTER" spacing="12">
         <children>
            <StackPane prefWidth="268.0" style="-fx-background-color: #6366f1; -fx-background-radius: 12;">
               <children>
                  <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 24px;" text="LMS" />
               </children>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
               <padding>
                  <Insets bottom="10.0" top="10.0" />
               </padding>
            </StackPane>
            <Region prefHeight="10" />
         </children>
      </VBox>

        <VBox alignment="TOP_CENTER" prefHeight="65.0" prefWidth="338.0" spacing="12">

            <Region prefHeight="10" />

            <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #0f172a; -fx-letter-spacing: -0.5;" text="Sign in to Account" />
            <Label style="-fx-font-size: 14px; -fx-text-fill: #64748b;" text="Welcome back! Please enter your details." />
         <effect>
            <Bloom threshold="1.0" />
         </effect>
        </VBox>

        <Region prefHeight="40" />

        <VBox spacing="24">
            <VBox spacing="8">
                <Label style="-fx-font-weight: bold; -fx-text-fill: #334155; -fx-font-size: 13px;" text="Email or Username" />
                <TextField fx:id="usernameField" promptText="name@company.com" style="-fx-background-color: white; -fx-border-color: #cbd5e1;                                   -fx-border-radius: 10; -fx-background-radius: 10;                                   -fx-padding: 14; -fx-font-size: 14px;" />
            </VBox>

            <VBox spacing="8">
                <HBox alignment="CENTER_LEFT">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #334155; -fx-font-size: 13px;" text="Password" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Hyperlink style="-fx-text-fill: #6366f1; -fx-font-size: 13px; -fx-padding: 0;" text="Forgot?" />
                </HBox>
                <PasswordField fx:id="passwordField" promptText="••••••••" style="-fx-background-color: white; -fx-border-color: #cbd5e1;                                       -fx-border-radius: 10; -fx-background-radius: 10;                                       -fx-padding: 14; -fx-font-size: 14px;" />
            </VBox>
        </VBox>

        <Region prefHeight="32" />

        <Button fx:id="loginButton" defaultButton="true" maxWidth="Infinity" onAction="#handleLogin" style="-fx-background-color: #0f172a; -fx-text-fill: white; -fx-font-weight: bold;                        -fx-font-size: 15px; -fx-background-radius: 10; -fx-padding: 15;                        -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(15,23,42,0.2), 10, 0, 0, 4);" text="Sign in" />

        <Region prefHeight="20" />

        <Label fx:id="messageLabel" style="-fx-text-fill: #e11d48; -fx-font-size: 13px; -fx-padding: 10 0 0 0;" text="" textAlignment="CENTER" textFill="RED" wrapText="true" />

    </VBox>
</StackPane>
