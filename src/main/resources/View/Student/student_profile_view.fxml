<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="14" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.java_lms_group_20.Controller.Student.StudentProfileController">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    <Label text="My Profile" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
    <Label text="Student ID:"/>
    <Label fx:id="lblStudentId" style="-fx-font-weight: bold;"/>
    <Label text="Name:"/>
    <Label fx:id="lblName" style="-fx-font-weight: bold;"/>
    <TextField fx:id="txtContact" promptText="Contact Number"/>
    <HBox spacing="10">
        <Button text="Save" onAction="#handleSave" style="-fx-background-color: #10b981; -fx-text-fill: white;"/>
        <Label fx:id="lblStatus"/>
    </HBox>
</VBox>
