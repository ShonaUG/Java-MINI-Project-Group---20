<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="25" style="-fx-background-color: #f1f5f9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.java_lms_group_20.Controller.Admin.AdminDashboardHomeController">
    <padding>
        <Insets bottom="30" left="30" right="30" top="30" />
    </padding>

    <HBox spacing="20">
        <children>
            <VBox prefWidth="200.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                <children>
                    <Label text="Total Students" style="-fx-text-fill: #64748b; -fx-font-size: 14px;" />
                    <Label fx:id="lblTotalStudents" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #6366f1;" />
                </children>
            </VBox>
            <VBox prefWidth="200.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                <children>
                    <Label text="Active Courses" style="-fx-text-fill: #64748b; -fx-font-size: 14px;" />
                    <Label fx:id="lblTotalCourses" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #10b981;" />
                </children>
            </VBox>
            <VBox prefWidth="200.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                <children>
                    <Label text="Faculty Members" style="-fx-text-fill: #64748b; -fx-font-size: 14px;" />
                    <Label fx:id="lblTotalFaculty" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #f59e0b;" />
                </children>
            </VBox>
        </children>
    </HBox>

    <VBox VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5);">
        <padding><Insets bottom="10" left="10" right="10" top="10" /></padding>
        <children>
            <TabPane tabClosingPolicy="UNAVAILABLE"
                     VBox.vgrow="ALWAYS"
                     style="-fx-padding: 0; -fx-tab-min-width: 120px; -fx-tab-min-height: 40px; -fx-cursor: hand;">
                <tabs>
                    <Tab text="Student List">
                        <VBox style="-fx-padding: 15;">
                            <TableView fx:id="studentTable" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colStuID" text="Student ID" />
                                    <TableColumn fx:id="colStuName" text="Full Name" />
                                    <TableColumn fx:id="colStuDegree" text="Degree Program" />
                                </columns>
                                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                            </TableView>
                        </VBox>
                    </Tab>

                    <Tab text="Lecturers">
                        <VBox style="-fx-padding: 15;">
                            <TableView fx:id="lecturerTable" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colLecID" text="Lecturer ID" />
                                    <TableColumn fx:id="colLecName" text="Full Name" />
                                    <TableColumn fx:id="colLecDept" text="Department" />
                                </columns>
                                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                            </TableView>
                        </VBox>
                    </Tab>

                    <Tab text="Technical Officers">
                        <VBox style="-fx-padding: 15;">
                            <TableView fx:id="toTable" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colTOID" text="Staff ID" />
                                    <TableColumn fx:id="colTOName" text="Staff Name" />
                                    <TableColumn fx:id="colTODept" text="Department" />
                                    <TableColumn fx:id="colTOSkills" text="Skills" />
                                </columns>
                                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                            </TableView>
                        </VBox>
                    </Tab>

                    <Tab text="Courses">
                        <VBox style="-fx-padding: 15;">
                            <TableView fx:id="courseTable" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colCourseCode" text="Code" />
                                    <TableColumn fx:id="colCourseName" text="Module Title" />
                                    <TableColumn fx:id="colCourseCredits" text="Credits" />
                                </columns>
                                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                            </TableView>
                        </VBox>
                    </Tab>
                </tabs>
            </TabPane>
        </children>
    </VBox>
</VBox>