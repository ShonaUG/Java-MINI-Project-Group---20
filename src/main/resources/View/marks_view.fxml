<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 15;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.java_lms_group_20.Controller.MarksController">
    <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>
    <Label text="Student Marks Management" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
    <HBox spacing="10">
        <TextField fx:id="txtSearchID" promptText="Search Student ID" prefWidth="250"/>
        <Button text="Search" onAction="#handleSearch" style="-fx-background-color: #6366f1; -fx-text-fill: white;"/>
    </HBox>
    <TableView fx:id="marksTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colStuID" text="Student ID" />
            <TableColumn fx:id="colCourse" text="Course" />
            <TableColumn fx:id="colCA" text="CA" />
            <TableColumn fx:id="colMid" text="Mid" />
            <TableColumn fx:id="colEnd" text="End" />
            <TableColumn fx:id="colFinal" text="Final" />
            <TableColumn fx:id="colGrade" text="Grade" />
        </columns>
        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
    </TableView>
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="txtCA" promptText="CA Marks" prefWidth="80"/>
        <TextField fx:id="txtMid" promptText="Mid Exam" prefWidth="80"/>
        <TextField fx:id="txtEnd" promptText="End Exam" prefWidth="80"/>
        <Button text="Update &amp; Calculate" onAction="#handleUpdate" style="-fx-background-color: #10b981; -fx-text-fill: white;"/>
        <Label fx:id="lblStatus" />
    </HBox>
</VBox>