<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.java_lms_group_20.Controller.DashboardController"
            prefWidth="900.0" prefHeight="600.0">

    <top>
        <VBox spacing="10" style="-fx-background-color: #2c3e50;" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <Label text="Dashboard"
                   style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;" />
            <Label fx:id="welcomeLabel"
                   text="Welcome!"
                   style="-fx-text-fill: #ecf0f1; -fx-font-size: 16px;" />
        </VBox>
    </top>

    <left>
        <VBox spacing="12"
              prefWidth="200"
              style="-fx-background-color: #34495e;"
              BorderPane.alignment="CENTER">
            <padding>
                <Insets top="20" right="15" bottom="20" left="15"/>
            </padding>

            <Label text="Menu"
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />

            <Button text="Home" maxWidth="Infinity" onAction="#handleHome"/>
            <Button text="Profile" maxWidth="Infinity" onAction="#handleProfile"/>
            <Button text="Courses" maxWidth="Infinity" onAction="#handleCourses"/>
            <Button text="Student Register" maxWidth="Infinity" onAction="#studentregister"/>
            <Button text="Logout" maxWidth="Infinity" onAction="#handleLogout"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="15" alignment="CENTER">
            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>

            <Label text="Dashboard Overview" style="-fx-font-size: 22px; -fx-font-weight: bold;" />
            <Label fx:id="statusLabel" text="You are successfully logged in." />
        </VBox>
    </center>

</BorderPane>