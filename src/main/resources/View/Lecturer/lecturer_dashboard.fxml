<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #f8fafc;"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.java_lms_group_20.Controller.Lecturer.LecturerDashboardController">

    <left>
        <VBox prefWidth="250.0" spacing="10" style="-fx-background-color: #0f172a;">
            <padding>
                <Insets top="30" right="15" bottom="30" left="15"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane style="-fx-background-color: #0ea5e9; -fx-background-radius: 8; -fx-padding: 8;">
                    <Label text="LMS" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                </StackPane>
                <Label text="Lecturer Portal" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18px;"/>
            </HBox>

            <Region prefHeight="40"/>

            <Button fx:id="btnHome" onAction="#showHome" maxWidth="Infinity" alignment="BASELINE_LEFT" text="Dashboard Home"
                    style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-padding: 12; -fx-cursor: hand;"/>

            <Button fx:id="btnAttendance" onAction="#showAttendance" maxWidth="Infinity" alignment="BASELINE_LEFT" text="Mark Attendance"
                    style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-padding: 12; -fx-cursor: hand;"/>

            <Button fx:id="btnMarks" onAction="#showMarks" maxWidth="Infinity" alignment="BASELINE_LEFT" text="Manage Marks"
                    style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-padding: 12; -fx-cursor: hand;"/>

            <Button fx:id="btnMedical" onAction="#showMedical" maxWidth="Infinity" alignment="BASELINE_LEFT" text="View Medicals"
                    style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-padding: 12; -fx-cursor: hand;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button onAction="#handleSignOut" maxWidth="Infinity" text="Sign Out"
                    style="-fx-background-color: #ef444422; -fx-text-fill: #ef4444; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 8; -fx-cursor: hand;"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="25">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>

            <HBox alignment="CENTER_LEFT">
                <VBox spacing="5">
                    <Label fx:id="lblWelcome" text="Welcome, Lecturer"
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                    <HBox spacing="10">
                        <Label text="Staff ID:" style="-fx-font-size: 14px; -fx-text-fill: #64748b;"/>
                        <Label fx:id="lblLecturerID" text="LC1023" style="-fx-font-size: 14px; -fx-text-fill: #0ea5e9; -fx-font-weight: bold;"/>
                    </HBox>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Circle radius="22" fill="#e2e8f0"/>
            </HBox>

            <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                <Label text="Select an option from the menu to manage courses or students." style="-fx-text-fill: #94a3b8;"/>
            </StackPane>
        </VBox>
    </center>
</BorderPane>